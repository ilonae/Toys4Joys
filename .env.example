# ═══════════════════════════════════════════════════════════
#  TOYS4JOYS — Environment Variables Template
#  Copy to .env.local for local dev and fill in your values.
#  NEVER commit .env or .env.local to git.
# ═══════════════════════════════════════════════════════════

# ── Launch toggle ────────────────────────────────────────
# Set to "false" locally to bypass the coming-soon page.
# Leave unset (or "true") in Vercel production env vars.
VITE_COMING_SOON=false

# ── Supabase ─────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Stripe (use TEST keys for local/staging, LIVE for prod) ──
# https://dashboard.stripe.com/test/apikeys  (test)
# https://dashboard.stripe.com/apikeys       (live)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_...
STRIPE_SECRET_KEY=sk_test_or_sk_live_...

# ── Stripe Webhook (server-side only) ────────────────────
# Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase Service Role (server-side only, never VITE_) ─
# Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Brevo (transactional email) ───────────────────────────
# app.brevo.com → SMTP & API → API Keys → Generate a new API key
# Free plan: 300 emails/day, custom domain after DNS verification
BREVO_API_KEY=xkeysib-...
